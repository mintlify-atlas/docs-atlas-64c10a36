  "keyFeatures": [
    "User authentication with matricula and password",
    "Classroom (salones) management with building assignments",
    "Inventory tracking for furniture and equipment",
    "Classroom reservation system",
    "Equipment loan (prestamos) management",
    "Admin dashboard with activity logs and statistics",
    "Reporting module for operational insights",
    "Cross-platform mobile app (iOS/Android) via Ionic/Capacitor",
    "REST API backend built with Java EE (JAX-RS)"
  ],
